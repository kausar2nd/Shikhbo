# ─── Flask Secret Key ───
# Used for session encryption. Generate a random string.
SECRET_KEY=your_flask_secret_key_here

# ─── NeonDB Postgres ───
# Connection string for the NeonDB PostgreSQL database.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Google Gemini ───
# API key for Google Generative AI (used for Gemma-4 31B IT model).
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── HuggingFace ───
# Access token for HuggingFace Inference API (embeddings & reranking).
# Get yours at: https://huggingface.co/settings/tokens
HF_ACCESS_TOKEN=your_hf_access_token_here
